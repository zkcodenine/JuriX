# Banco de dados
DATABASE_URL=postgresql://jurix_user:jurix_secret_2024@localhost:5432/jurix

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=troque_este_valor_por_um_segredo_muito_longo_e_aleatorio
JWT_EXPIRES_IN=7d

# Backend
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase (auth e pagamentos)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_chave_anonima_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# DataJud CNJ
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_mercadopago
