# ============================================================
# JURIX — Variáveis de Ambiente (raiz do projeto)
# Copie este arquivo para .env e preencha os valores.
# As variáveis principais ficam em backend/.env
# ============================================================

# Banco de dados (HostGator MySQL)
# Formato: mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO
DATABASE_URL=mysql://cpaneluser_jurix:SUA_SENHA@SEU_HOST.hostgator.com.br:3306/cpaneluser_jurix

# Redis
REDIS_URL=

# JWT
JWT_SECRET=troque_este_valor_por_um_segredo_muito_longo_e_aleatorio
JWT_EXPIRES_IN=7d

# Backend
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# DataJud CNJ
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_mercadopago
MERCADOPAGO_PUBLIC_KEY=sua_public_key_mercadopago
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret

# Email (Resend)
RESEND_API_KEY=sua_api_key_resend
EMAIL_FROM=noreply@jurix.com.br

# Armazenamento local
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# Monitoramento (intervalo em minutos)
MONITOR_INTERVAL_MINUTES=180
