# ═══════════════════════════════════════════════════════════
#  JuriX — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════

# ─── Banco de Dados (Supabase ou PostgreSQL local) ────────
# Para Supabase: copie a connection string do dashboard
#   Settings > Database > Connection string > URI (com pgBouncer)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Conexão direta (sem pgBouncer) — usado apenas para migrations (npx prisma migrate)
#   Settings > Database > Connection string > URI (direct)
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Para PostgreSQL local (desenvolvimento):
# DATABASE_URL=postgresql://jurix_user:jurix_secret_2024@localhost:5432/jurix
# DIRECT_URL=postgresql://jurix_user:jurix_secret_2024@localhost:5432/jurix

# ─── Redis (opcional — fallback para cache em memória) ────
REDIS_URL=redis://localhost:6379

# ─── Autenticação JWT ─────────────────────────────────────
JWT_SECRET=troque_por_string_longa_e_aleatoria
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── APIs de Tribunais ────────────────────────────────────
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# ─── InfoSimples API (consulta tribunais estaduais) ───────
INFOSIMPLES_TOKEN=seu_token_infosimples

# ─── Monitoramento de Processos ───────────────────────────
MONITOR_INTERVAL_MINUTES=30

# ─── Pagamentos (Mercado Pago) ────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=seu_access_token

# ─── E-mail (Resend) ─────────────────────────────────────
RESEND_API_KEY=sua_api_key
EMAIL_FROM=noreply@jurix.com.br

# ─── Storage ──────────────────────────────────────────────
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50
