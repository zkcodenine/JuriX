# ═══════════════════════════════════════════════════════════
#  JuriX — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════

# ─── Banco de Dados (HostGator MySQL ou MySQL local) ──────
# Formato HostGator (cPanel > MySQL Databases):
#   mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO
# Onde:
#   USUARIO        = usuário criado no cPanel (geralmente prefixado: cpaneluser_jurix)
#   SENHA          = senha do usuário do banco
#   HOST           = hostname do servidor MySQL (ex: br123.hostgator.com.br ou seu domínio)
#   NOME_DO_BANCO  = nome completo do banco (ex: cpaneluser_jurix)
#
# IMPORTANTE: Em "Remote MySQL" do cPanel, libere o IP do servidor que
# rodará a aplicação JuriX (ou use % para liberar qualquer IP — menos seguro).
DATABASE_URL=mysql://cpaneluser_jurix:SUA_SENHA@SEU_HOST.hostgator.com.br:3306/cpaneluser_jurix

# Para MySQL local (desenvolvimento via Docker):
# DATABASE_URL=mysql://jurix_user:jurix_secret_2024@localhost:3306/jurix

# ─── Redis (opcional — fallback para cache em memória) ────
REDIS_URL=
REDIS_DISABLED=true

# ─── Autenticação JWT ─────────────────────────────────────
JWT_SECRET=troque_por_string_longa_e_aleatoria
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── APIs de Tribunais ────────────────────────────────────
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# ─── InfoSimples API (consulta tribunais estaduais) ───────
INFOSIMPLES_TOKEN=seu_token_infosimples

# ─── Monitoramento de Processos ───────────────────────────
MONITOR_INTERVAL_MINUTES=30

# ─── Pagamentos (Mercado Pago) ────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=seu_access_token
# Link de pagamento fixo do plano Mensal
MERCADOPAGO_LINK_MENSAL=https://mpago.la/xxxxxx

# ─── Google Agenda (OAuth 2.0 — Google Calendar API) ──────
# console.cloud.google.com → Credentials → OAuth client ID (Web application)
# Redirect URI: http://localhost:3001/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# ─── E-mail (Resend) ─────────────────────────────────────
RESEND_API_KEY=sua_api_key
EMAIL_FROM=noreply@jurix.com.br

# ─── Storage ──────────────────────────────────────────────
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# ─── Migração de dados (apenas durante migração Supabase → HostGator) ──
# Aponta para o banco PostgreSQL antigo. Usado por scripts/export-supabase.js.
# Após a migração concluída, pode ser removida.
LEGACY_SUPABASE_URL=
